<div id="dt-tabs">
    <ul>
        <li><a href="#dt-tab-items">Items</a></li>
        <li><a href="#dt-tab-exportimport">Export/Import</a></li>
        <li><a href="#dt-tab-settings">Settings</a></li>
    </ul>

    <div id="dt-tab-exportimport">
        <fieldset>
            <legend>As Text</legend>
            <div class="drawtoolsSetbox">
                <a tabindex="0" id="dt-opt-copy">Copy Drawn Items</a>
                <a tabindex="0" id="dt-opt-paste">Paste Drawn Items</a>
            </div>
        </fieldset>
        <fieldset>
            <legend>As File</legend>
            <div class="drawtoolsSetbox">
                <a tabindex="0" id="dt-opt-export">Export Drawn Items</a>
                <a tabindex="0" id="dt-opt-import">Import Drawn Items</a>
            </div>
        </fieldset>
    </div>

    <div id="dt-tab-items"></div>

    <div id="dt-tab-settings">
        <fieldset>
            <legend>Settings</legend>
            <div class="drawtoolsStyles">
                Draw Color<!-- using a label here would trigger the native browser color selector -->
                <input type="color" name="drawColor" id="drawtools_color">
            </div>
            <label id="MergeToggle">
                <input type="checkbox" name="merge"{{#if mergeChecked}} checked{{/if}}>
                Reset draws before paste or import
            </label>
            <label id="edfToggle">
                <input type="checkbox" name="edf"{{#if edfChecked}} checked{{/if}}>
                Fill the polygon(s)
            </label>
        </fieldset>
        <fieldset>
            <legend>Actions</legend>
            <div class="drawtoolsSetbox">
                <a tabindex="0" id="dt-opt-snap">Snap to portals</a>
                <a tabindex="0" id="dt-opt-reset">Clear Drawn Items</a>
            </div>
        </fieldset>
    </div>
</div>
